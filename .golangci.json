{
    "version": "2",
    "run": {
        "tests": true
    },
    "formatters": {
        "enable": [
            "gofmt",
            "goimports"
        ]
    },
    "linters": {
        "enable": [
            "nestif",
            "asciicheck",
            "exhaustive",
            "copyloopvar",
            "forbidigo",
            "gocyclo",
            "makezero",
            "misspell",
            "nakedret",
            "nilerr",
            "nlreturn",
            "nolintlint",
            "testpackage",
            "unconvert",
            "wastedassign",
            "whitespace"
        ],
        "exclusions": {
            "paths": [
                "graph",
                ".*/generated/*"
            ]
        }
    }
}
